NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000


NEXT_PUBLIC_SCAN_API_URL=http://localhost:3001/scan

# AI API Key
HACKAI_KEY=sk-

SMSTO_API_KEY=

# ─── Billing System ──────────────────────────────────────────────────────────

# Secret for admin-only endpoints (POST /api/admin/invoices/issue)
# Generate with: openssl rand -hex 32
ADMIN_API_SECRET=

# Secret for the subscription cron endpoint (POST /api/subscriptions/check-expired)
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── SMTP (for invoice emails and payment confirmations) ─────────────────────
# Example values for Brevo (Sendinblue) — replace with your provider
SMTP_HOST=smtp.zo
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# ── Stripe ──────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from Dashboard → Webhooks → Add endpoint → stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Get from Dashboard → Products → your subscription product → Prices
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
